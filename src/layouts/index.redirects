# Netlify Redirects generated by Hugo
{{- range where .Site.RegularPages "Section" "publications" -}}
  {{- $slug := .File.ContentBaseName -}}
  {{- $target := "" -}}
  {{- if .Params.doi -}}
    {{- $target = printf "https://doi.org/%s" .Params.doi -}}
  {{- else if .Params.paper_url -}}
    {{- $target = .Params.paper_url -}}
  {{- end -}}
  {{- if $target -}}
    {{- printf "\n/%s  %s  301" $slug $target -}}
  {{- end -}}
{{- end }}

# SPA Fallback
/* /index.html  200